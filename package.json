{
  "name": "datatalk-text-to-sql",
  "version": "0.1.0",
  "private": true,
  "description": "A Text-to-SQL starter project for converting natural language into SQL queries.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/server.js",
    "server": "ts-node src/server.ts",
    "lint": "eslint . --ext .ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.28.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.14.2",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^33.0.0",
    "eslint-plugin-import": "^2.29.4",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-promise": "^6.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.4"
  }
}
